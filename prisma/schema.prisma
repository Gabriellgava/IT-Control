generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Usuario {
  id            String         @id @default(cuid())
  nome          String?
  email         String?        @unique
  emailVerified DateTime?      @map("email_verified")
  image         String?
  senha         String?
  perfil        String         @default("usuario")
  ativo         Boolean        @default(true)
  criadoEm      DateTime       @default(now()) @map("criado_em")
  accounts      Account[]
  sessions      Session[]
  movimentacoes Movimentacao[]

  @@map("usuarios")
}

model Categoria {
  id            String    @id @default(cuid())
  nome          String    @unique
  estoqueMinimo Int       @default(0) @map("estoque_minimo")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  produtos      Produto[]

  @@map("categorias")
}

model Fornecedor {
  id            String         @id @default(cuid())
  nome          String
  contato       String?
  email         String?
  telefone      String?
  site          String?
  criadoEm      DateTime       @default(now()) @map("criado_em")
  atualizadoEm  DateTime       @updatedAt @map("atualizado_em")
  produtos      Produto[]
  movimentacoes Movimentacao[]

  @@map("fornecedores")
}

model Setor {
  id            String         @id @default(cuid())
  nome          String         @unique
  criadoEm      DateTime       @default(now()) @map("criado_em")
  movimentacoes Movimentacao[]

  @@map("setores")
}

model Produto {
  id            String     @id @default(cuid())
  nome          String
  codigo        String     @unique
  categoriaId   String?    @map("categoria_id")
  categoria     Categoria? @relation(fields: [categoriaId], references: [id])
  fornecedorId  String?    @map("fornecedor_id")
  fornecedor    Fornecedor? @relation(fields: [fornecedorId], references: [id])
  valorUnitario Float      @default(0) @map("valor_unitario")
  linkCompra    String?    @map("link_compra")
  observacoes   String?
  criadoEm      DateTime   @default(now()) @map("criado_em")
  atualizadoEm  DateTime   @updatedAt @map("atualizado_em")
  unidades      Unidade[]

  @@map("produtos")
}

model Unidade {
  id            String         @id @default(cuid())
  produtoId     String         @map("produto_id")
  produto       Produto        @relation(fields: [produtoId], references: [id])
  etiqueta      String         @unique
  dataCompra    DateTime?      @map("data_compra")
  status        String         @default("ATIVA")
  criadoEm      DateTime       @default(now()) @map("criado_em")
  movimentacoes Movimentacao[]

  @@map("unidades")
}

model Movimentacao {
  id            String      @id @default(cuid())
  tipo          String
  subtipo       String?
  unidadeId     String      @map("unidade_id")
  unidade       Unidade     @relation(fields: [unidadeId], references: [id])
  valorUnitario Float       @default(0) @map("valor_unitario")
  data          DateTime    @default(now())
  fornecedorId  String?     @map("fornecedor_id")
  fornecedor    Fornecedor? @relation(fields: [fornecedorId], references: [id])
  setorId       String?     @map("setor_id")
  setor         Setor?      @relation(fields: [setorId], references: [id])
  usuarioId     String?     @map("usuario_id")
  usuario       Usuario?    @relation(fields: [usuarioId], references: [id])
  responsavel   String?
  observacoes   String?
  cancelado     Boolean     @default(false)
  canceladoEm   DateTime?   @map("cancelado_em")
  canceladoPor  String?     @map("cancelado_por")
  criadoEm      DateTime    @default(now()) @map("criado_em")

  @@map("movimentacoes")
}
// ADICIONAR AO FINAL DO schema.prisma

model Inventario {
  id           String   @id @default(cuid())
  setor        String
  responsavel  String
  tipo         String
  marca        String
  modelo       String
  etiqueta     String   @unique
  numero       String?  @map("numero")
  observacoes  String?
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("inventario")
}
